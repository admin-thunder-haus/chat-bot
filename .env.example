# ---------------------------------------------------------------------------
# Root environment file used by docker-compose.
# Copy to `.env` and adjust values. NEVER commit the real `.env`.
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- Ports ---
BACKEND_PORT=4000
FRONTEND_PORT=3000

# --- URLs ---
FRONTEND_URL=http://localhost:3000
# Browser-facing base URL for the backend API (used by the frontend).
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Database ---
# Inside docker-compose the backend reaches Postgres via the service name `postgres:5432`.
# When running the backend locally (outside docker) use `localhost:5433`.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_support?schema=public

POSTGRES_DB=ai_support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Host port that maps to the container's 5432 (avoids clashing with a local Postgres).
POSTGRES_HOST_PORT=5433

# --- JWT ---
# Generate strong secrets, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Cookies ---
# In production set COOKIE_SECURE=true and serve over HTTPS.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# --- CORS ---
# Comma-separated allowlist of origins permitted to call the API.
CORS_ORIGINS=http://localhost:3000

# --- Security / limits ---
BCRYPT_SALT_ROUNDS=12
JSON_BODY_LIMIT=100kb

# --- Rate limiting ---
# General API budget (per IP per window). Generous enough for real dashboard use.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
# Login / register — strict brute-force + signup-abuse protection.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
# Token refresh — its own short-window budget so rotation never hits the login limit.
REFRESH_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX=60

# --- Day 4: AI (OpenAI) ---
# AI is OFF by default. Set AI_FEATURE_ENABLED=true AND provide OPENAI_API_KEY to enable.
# Uses the OpenAI API (NOT a ChatGPT Plus subscription). Key stays server-side only.
AI_FEATURE_ENABLED=false
AI_AUTO_REPLY_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.3
AI_CONTEXT_MAX_CHARACTERS=30000
AI_CONVERSATION_HISTORY_LIMIT=12
AI_DAILY_COMPANY_REQUEST_LIMIT=1000
AI_MONTHLY_COMPANY_TOKEN_LIMIT=1000000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=30

# --- Day 5 Part 1: channel integration framework ---
# Credential encryption (AES-256-GCM). Required only once a provider stores
# credentials (the fake provider needs none). Generate a base64 32-byte key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CHANNEL_CREDENTIAL_ENCRYPTION_KEY=
CHANNEL_CREDENTIAL_ENCRYPTION_VERSION=v1

# Public webhook engine limiter — a separate budget from the API/dashboard.
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=300

# Development fake/test channel. Disabled by default; NEVER active in production
# regardless of this flag. Provide a webhook secret + verify token to use it.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
FAKE_CHANNEL_ENABLED=false
FAKE_CHANNEL_WEBHOOK_SECRET=
FAKE_CHANNEL_VERIFY_TOKEN=

# --- Day 5 Part 2: delivery engine / retry policy ---
# Total attempts (first send + retries) before a temporary failure is permanent.
CHANNEL_DELIVERY_MAX_ATTEMPTS=3
# Exponential backoff: delay = base * factor^(attempt-1), capped at max (ms), + jitter.
CHANNEL_DELIVERY_BACKOFF_BASE_MS=1000
CHANNEL_DELIVERY_BACKOFF_FACTOR=2
CHANNEL_DELIVERY_BACKOFF_MAX_MS=300000
CHANNEL_DELIVERY_BACKOFF_JITTER=0.2
# A delivery not sent within this window is EXPIRED (default 24h).
CHANNEL_DELIVERY_TTL_MS=86400000

# --- Day 5 Part 3: Web Chat widget ---
# Secret used to sign stateless widget session tokens (min 32 chars). Required
# once a Web Chat channel is used. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WIDGET_SESSION_SECRET=
# Visitor reconnect window (session token lifetime). Default 30 days.
WIDGET_SESSION_TTL_MS=2592000000
# Public widget API limiter (separate budget; sized for polling).
WIDGET_RATE_LIMIT_WINDOW_MS=60000
WIDGET_RATE_LIMIT_MAX=240

# --- Day 6: WhatsApp Business Cloud API (Meta) ---
# NON-secret global config only. Per-account secrets (access token, app secret,
# verify token) are provided at connect time and stored ENCRYPTED per account
# (reuses CHANNEL_CREDENTIAL_ENCRYPTION_KEY) — NEVER via env.
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_REQUEST_TIMEOUT_MS=15000

# --- Day 7: Instagram Messaging (Meta) ---
# NON-secret global config only. Per-account secrets (access token, app secret,
# verify token) are provided at connect time and stored ENCRYPTED per account
# (reuses CHANNEL_CREDENTIAL_ENCRYPTION_KEY) — NEVER via env.
# Set INSTAGRAM_PROVIDER_ENABLED=false to hide/disable the provider entirely.
INSTAGRAM_PROVIDER_ENABLED=true
INSTAGRAM_GRAPH_API_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_API_VERSION=v21.0
INSTAGRAM_API_TIMEOUT_MS=15000
