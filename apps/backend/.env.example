# Backend env for running LOCALLY (outside Docker). Copy to apps/backend/.env
# When running via docker-compose, values come from the root .env instead.

NODE_ENV=development
BACKEND_PORT=4000

# Local dev connects to the Postgres container exposed on host port 5433.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_support?schema=public

JWT_ACCESS_SECRET=dev-access-secret-change-me-at-least-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-at-least-32-chars-diff
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

CORS_ORIGINS=http://localhost:3000

BCRYPT_SALT_ROUNDS=12
JSON_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
REFRESH_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX=60

# Separate database for the test suite (never the dev DB).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_support_test?schema=public

# --- Email verification (registration) ---
# When true, new registrations must confirm a 6-digit emailed code before
# logging in. Without SMTP_HOST the mailer logs emails instead of sending, so
# dev works without an SMTP account (read the code from the server logs).
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_CODE_TTL_MS=900000
EMAIL_VERIFICATION_RESEND_COOLDOWN_MS=60000
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AI Support <no-reply@localhost>

# --- Day 4: AI (OpenAI) ---
AI_FEATURE_ENABLED=false
AI_AUTO_REPLY_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.3
AI_CONTEXT_MAX_CHARACTERS=30000
AI_CONVERSATION_HISTORY_LIMIT=12
AI_DAILY_COMPANY_REQUEST_LIMIT=1000
AI_MONTHLY_COMPANY_TOKEN_LIMIT=1000000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=30

# --- Day 11: voice transcription + PDF knowledge ---
# Voice notes are transcribed with OpenAI (uses OPENAI_API_KEY) when AI is on.
AI_TRANSCRIPTION_ENABLED=true
OPENAI_TRANSCRIPTION_MODEL=whisper-1
# Per-file size cap for uploaded knowledge PDFs (MB).
KNOWLEDGE_DOC_MAX_FILE_MB=10

# --- Day 7: Instagram Messaging (Meta) — non-secret global config ---
# Per-account secrets are supplied at connect time + encrypted (never via env).
INSTAGRAM_PROVIDER_ENABLED=true
INSTAGRAM_GRAPH_API_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_API_VERSION=v21.0
INSTAGRAM_API_TIMEOUT_MS=15000

# --- Day 8: Facebook Messenger (Meta) — non-secret global config ---
FACEBOOK_PROVIDER_ENABLED=true
FACEBOOK_GRAPH_API_BASE_URL=https://graph.facebook.com
FACEBOOK_GRAPH_API_VERSION=v21.0
FACEBOOK_API_TIMEOUT_MS=15000

# --- Day 9: Telegram Bot API — non-secret global config ---
TELEGRAM_PROVIDER_ENABLED=true
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_API_TIMEOUT_MS=15000

# --- Day 12: Meta OAuth / Embedded Signup (one-click channel connect) ---
# Optional. When META_APP_ID/META_APP_SECRET are unset the OAuth flow is
# disabled and manual connect remains the only path. See docs/META-OAUTH.md.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
# Embedded Signup configuration id (WhatsApp product in the Meta app).
WHATSAPP_ES_CONFIG_ID=
# Facebook Login for Business configuration id (Messenger + Instagram).
META_LOGIN_CONFIG_ID=
# Where the browser lands after the OAuth callback (the dashboard origin).
FRONTEND_APP_URL=http://localhost:3000

# --- Day 12: billing & subscriptions ---
# Free-trial length for new companies (days).
BILLING_TRIAL_DAYS=14
# Stripe is OPTIONAL. Leave STRIPE_SECRET_KEY empty for OFFLINE billing mode
# (plan changes apply immediately, no checkout). Set both for hosted checkout
# with verified webhooks (POST /api/v1/billing/webhook/stripe).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Day 12: AI actions ---
# Master switch for AI-performed business actions (book appointments, create
# orders/support tickets, availability lookups). Per-company AI settings and
# AI_FEATURE_ENABLED still gate whether the AI replies at all.
AI_ACTIONS_ENABLED=true
