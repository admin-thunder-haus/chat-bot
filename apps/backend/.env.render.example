# ============================================================================
# TEMPLATE for the BACKEND production env on Render (safe to commit).
# Copy to apps/backend/.env.render and fill in the real values, then paste
# those into Render → Web Service → Environment.
# ============================================================================

NODE_ENV=production
BACKEND_PORT=10000

# Neon Postgres — pooled URL for the app, direct URL for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_HEX_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_HEX_CHARS_MIN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cross-site cookies (frontend on a different origin than the Render backend).
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

# Comma-separated allowlist of browser origins that call this API.
CORS_ORIGINS=http://localhost:3000

BCRYPT_SALT_ROUNDS=12
JSON_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
REFRESH_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX=60

# --- Email verification (registration) ---
# Configure a real SMTP provider in production; without SMTP_HOST the mailer
# only logs the codes to the Render logs (works, but not user-friendly).
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_CODE_TTL_MS=900000
EMAIL_VERIFICATION_RESEND_COOLDOWN_MS=60000
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
EMAIL_FROM=AI Support <no-reply@yourdomain.com>

AI_FEATURE_ENABLED=true
AI_AUTO_REPLY_ENABLED=false
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# base64-encoded 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CHANNEL_CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
CHANNEL_CREDENTIAL_ENCRYPTION_VERSION=v1
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=300
FAKE_CHANNEL_ENABLED=false

CHANNEL_DELIVERY_MAX_ATTEMPTS=3
CHANNEL_DELIVERY_BACKOFF_BASE_MS=1000
CHANNEL_DELIVERY_BACKOFF_FACTOR=2
CHANNEL_DELIVERY_BACKOFF_MAX_MS=300000
CHANNEL_DELIVERY_BACKOFF_JITTER=0.2
CHANNEL_DELIVERY_TTL_MS=86400000

WIDGET_SESSION_SECRET=CHANGE_ME_64_HEX_CHARS
WIDGET_SESSION_TTL_MS=2592000000
WIDGET_RATE_LIMIT_WINDOW_MS=60000
WIDGET_RATE_LIMIT_MAX=240

WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_REQUEST_TIMEOUT_MS=15000

# --- Day 7: Instagram Messaging (Meta) — non-secret global config ---
INSTAGRAM_PROVIDER_ENABLED=true
INSTAGRAM_GRAPH_API_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_API_VERSION=v21.0
INSTAGRAM_API_TIMEOUT_MS=15000

# --- Day 8: Facebook Messenger (Meta) — non-secret global config ---
FACEBOOK_PROVIDER_ENABLED=true
FACEBOOK_GRAPH_API_BASE_URL=https://graph.facebook.com
FACEBOOK_GRAPH_API_VERSION=v21.0
FACEBOOK_API_TIMEOUT_MS=15000

# --- Day 9: Telegram Bot API — non-secret global config ---
TELEGRAM_PROVIDER_ENABLED=true
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_API_TIMEOUT_MS=15000
